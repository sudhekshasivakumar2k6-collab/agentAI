# ─────────────────────────────────────────────────────────────
# Multi-Modal Assistant – Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# AWS Credentials (leave blank when using IAM roles / instance profiles)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

# S3
S3_BUCKET_NAME=multi-modal-assistant-bucket
S3_PRESIGNED_URL_EXPIRY=3600

# Amazon Bedrock – Chat Model
BEDROCK_CHAT_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=2048

# Amazon Bedrock – Image Model
BEDROCK_IMAGE_MODEL_ID=stability.stable-diffusion-xl-v1

# Amazon Polly
POLLY_VOICE_ID=Joanna
POLLY_ENGINE=neural
POLLY_OUTPUT_FORMAT=mp3

# Amazon Transcribe
TRANSCRIBE_LANGUAGE_CODE=en-US
TRANSCRIBE_MEDIA_FORMAT=webm
TRANSCRIBE_JOB_POLL_INTERVAL=2.0

# Application
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
APP_LOG_LEVEL=INFO
APP_SYSTEM_PROMPT="You are a helpful, friendly, and knowledgeable AI assistant. Keep responses concise unless asked for detail."
